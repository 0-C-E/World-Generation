# =========================================================================
#  World Generation Settings
# =========================================================================
#
#  Copy this file to `.env` and uncomment the lines you want to change.
#  All values are optional -- leave them commented out to use defaults.
#  Restart the generator / viewer after editing (no recompile needed).
#
# =========================================================================


# ── Map Size ────────────────────────────────────────────────────────────
# How big the world is. This is the side length of the square map, in tiles.
# A 10000x10000 map has 100 million tiles total.
#
#   Lower (e.g. 200)  = smaller world, faster to generate, fewer islands
#   Higher (e.g. 20000) = massive world, slower generation, many more islands
#
# For a small private server with friends, try 200-1000.
# For a large public server, 10000+ gives plenty of room.
#
MAP_SIZE=1000


# ── Chunk Size ──────────────────────────────────────────────────────────
# How the map is split into pieces internally. You almost never need to
# touch this -- "auto" picks the best value based on your map size.
# Only change it if you know what you're doing.
#
CHUNK_SIZE=auto


# ── Seed ────────────────────────────────────────────────────────────────
# The world seed, like in Minecraft. The same seed always produces the
# exact same world. Leave it empty to get a random world each time you
# generate.
#
# Share your seed with others so they can explore the same map!
#
# SEED=42


# ── Terrain Shape ───────────────────────────────────────────────────────
# These control the overall look of the terrain -- how the islands are
# shaped, how rough the coastlines are, and how much land vs ocean there
# is. The defaults produce a nice mix of large and small islands.

# SCALE -- Controls the "zoom level" of the terrain noise.
#   Lower (e.g. 20.0)  = many tiny islands, like an archipelago
#   Higher (e.g. 100.0) = fewer but much larger landmasses
#
SCALE=50.0

# OCTAVES -- How many layers of detail are blended together.
#   Lower (e.g. 2-3) = smooth, rounded islands with simple coastlines
#   Higher (e.g. 7-8) = jagged, complex coastlines with lots of inlets
#
OCTAVES=6

# PERSISTENCE -- How much the small details stand out.
#   Lower (e.g. 0.3) = smoother terrain, less variation
#   Higher (e.g. 0.7) = rougher terrain with more dramatic features
#
PERSISTENCE=0.5

# LACUNARITY -- How quickly the detail layers get finer.
#   Lower (e.g. 1.5) = subtle, gradual detail
#   Higher (e.g. 3.5) = more contrast between large shapes and fine detail
#
LACUNARITY=2.5


# ── Water vs Land ───────────────────────────────────────────────────────
# WATER_THRESHOLD -- The cutoff that decides what's ocean and what's land.
# Think of it as a "sea level" slider, from 0.0 to 1.0.
#
#   Lower (e.g. 0.40) = more land, bigger islands, less ocean
#   Default (0.55)     = balanced mix of land and water
#   Higher (e.g. 0.70) = mostly ocean, only mountain peaks become islands
#
WATER_THRESHOLD=0.55


# ── Playable Area ──────────────────────────────────────────────────────
# PLAYABLE_RADIUS_FRAC -- How much of the map is playable, as a fraction
# of half the map size. The rest becomes decorative border (FarLand).
#
#   0.8  = 80% of the radius is playable (larger border)
#   0.975 = almost the entire map is playable (default)
#   1.0  = no border at all
#
PLAYABLE_RADIUS_FRAC=0.975

# FARLAND_MARGIN -- The width (in tiles) of the transition zone between
# the playable area and the decorative border. Defaults to 2x the city
# spacing. You rarely need to change this.
#
# FARLAND_MARGIN=10


# ── City Placement ─────────────────────────────────────────────────────
# Cities are placed on coastlines -- land tiles next to the ocean.
# These settings control how many cities appear and how they're spaced.

# CITY_SPACING -- Minimum gap (in tiles) between two cities.
#   Lower (e.g. 3)  = cities packed closely together, more cities overall
#   Higher (e.g. 10) = cities spread far apart, fewer cities per island
#
CITY_SPACING=5

# MIN_CITY_SLOTS_PER_ISLAND -- Islands with fewer cities than this are
# thrown out entirely. This removes tiny rocks that can't support gameplay.
#
#   Lower (e.g. 2) = keep even very small islands
#   Higher (e.g. 10) = only keep meaningful islands with room for players
#
MIN_CITY_SLOTS_PER_ISLAND=6

# MIN_WATER_BODY_SIZE -- How big a body of water needs to be (in tiles)
# for nearby cities to count as "coastal". This prevents cities from
# spawning next to tiny inland lakes instead of real ocean.
#
# Why it matters: sea attacks can only reach cities connected to the same
# ocean. A city on a small lake looks coastal but is effectively landlocked
# -- it can only be attacked by land. Setting this high enough ensures
# cities are only placed next to the main ocean, not random ponds.
#
#   Lower (e.g. 100)  = risky, lakes may count as coast (landlocked cities)
#   Default (500)      = safe for most maps, filters out small lakes
#   Higher (e.g. 1000) = stricter, only large seas and oceans count
#
# Rule of thumb: keep this at 500+ to avoid lakeside cities.
#
MIN_WATER_BODY_SIZE=500

# MIN_LAND_NEIGHBORS / MIN_WATER_NEIGHBORS -- How many of a tile's 4
# direct neighbors must be land or water for it to qualify as a city spot.
# This ensures cities sit on the coast, not deep inland or in the middle
# of the ocean.
#
MIN_LAND_NEIGHBORS=2
MIN_WATER_NEIGHBORS=2


# =========================================================================
#  Viewer Settings
# =========================================================================

# HOST -- Address and port for the map viewer web server.
# After generating a world, run the viewer and open this URL in your
# browser to explore the map.
#
#   0.0.0.0:8080 = accessible from other machines on your network
#   127.0.0.1:8080 = only accessible from this machine
#
HOST=0.0.0.0:8080
