# -- World Generation Settings -------------------------------------------
# Copy this file to `.env` and edit. All values are optional.
# Restart the generator / viewer after changing values (no recompile needed).

# Side length of the square world in tiles (default: 10000)
# MAP_SIZE=10000

# Chunk size in tiles. Set to "auto" or leave empty to compute automatically
# from MAP_SIZE (largest power-of-2 <= MAP_SIZE/20, clamped to 16..512).
# CHUNK_SIZE=auto

# Perlin noise seed. Leave empty for a random seed each run.
# SEED=42

# Base frequency of the noise (default: 50.0)
# SCALE=50.0

# Number of fractal noise octaves (default: 6)
# OCTAVES=6

# Amplitude decay per octave (default: 0.5)
# PERSISTENCE=0.5

# Frequency multiplier per octave (default: 2.5)
# LACUNARITY=2.5

# Elevation below this is water, range 0.0-1.0 (default: 0.55)
# WATER_THRESHOLD=0.55

# Playable radius as a fraction of half-map-size (default: 0.975)
# PLAYABLE_RADIUS_FRAC=0.975

# Minimum tile spacing between city slots (default: 5)
# CITY_SPACING=5

# Gap in tiles between the playable radius and where FarLand begins.
# Defaults to 2x CITY_SPACING (e.g. 10 tiles for spacing=5).
# FARLAND_MARGIN=10

# Islands with fewer city slots than this are excluded (default: 6)
# MIN_CITY_SLOTS_PER_ISLAND=6

# Minimum water body size in tiles for coastal cities (default: 500)
# MIN_WATER_BODY_SIZE=500

# Minimum land / water neighbours for city placement (defaults: 2 / 2)
# MIN_LAND_NEIGHBORS=2
# MIN_WATER_NEIGHBORS=2

# -- Viewer Settings -----------------------------------------------------

# Address and port for the HTTP viewer (default: 0.0.0.0:8080)
# HOST=0.0.0.0:8080
